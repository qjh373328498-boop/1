## 完整工作流脚本

### make_video_with_ai.sh

```bash
#!/bin/bash
# 一体化视频生成脚本（ModelScope AI 增强版）
# 用法：./make_video_with_ai.sh <主题> <时长> <输出目录>

set -e

THEME="$1"        # 主题
DURATION="$2"     # 时长（秒）
OUTPUT_DIR="$3"   # 输出目录

echo "=========================================="
echo "🎬 开始视频制作"
echo "主题：$THEME"
echo "时长：${DURATION}秒"
echo "输出：$OUTPUT_DIR"
echo "=========================================="

mkdir -p "$OUTPUT_DIR"
cd "$OUTPUT_DIR"

# 0. 生成脚本（使用 CLAude）
echo "[1/8] 📝 生成视频脚本..."
# 这里调用 CLAUDE 生成 script.md
# script.md 已存在则跳过

# 1. 生成配音
echo "[2/8] 🎙️ 生成配音..."
python3 -m edge_tts \
  --voice zh-CN-YunxiNeural \
  --file script.md \
  --write-media narration.mp3 \
  --write-subtitles narration.vtt

# 2. 生成分镜
echo "[3/8] 📋 生成分镜脚本..."
# 使用 Claude 分析脚本生成 storyboard.json

# 3. AI 图片生成
echo "[4/8] 🎨 AI 生成图片..."
python3 /workspace/.claude/scripts/gen_image.py batch.json

# 4. 图片处理
echo "[5/8] 🖼️ 处理图片..."
mkdir -p scaled
for img in *.png; do
  [ -f "$img" ] || continue
  ffmpeg -y -i "$img" \
    -vf "scale=1280:720:force_original_aspect_ratio=decrease,pad=1280:720:(ow-iw)/2:(oh-ih)/2,setsar=1" \
    "scaled/$img" 2>/dev/null
done

# 5. 合成视频
echo "[6/8] 🎬 合成视频..."
# 从 storyboard.json 读取每个场景的时长
ffmpeg -y \
  -loop 1 -t 20 -i scaled/cover.png \
  -loop 1 -t 30 -i scaled/components.png \
  # ... 更多场景 \
  -i narration.mp3 \
  -filter_complex "[0:v][1:v]...concat=n=9:v=1:a=0[outv]" \
  -map "[outv]" -map 9:a \
  -c:v libx264 -preset fast -crf 23 -c:a aac -b:a 192k \
  output.mp4

# 6. 生成 BGM（可选）
echo "[7/8] 🎵 生成背景音乐..."
# 调用 music-gen 或 ModelScope 音乐生成

# 7. 最终合成
echo "[8/8] ✨ 最终合成..."
# 合并 BGM、字幕等

echo "=========================================="
echo "✅ 视频制作完成！"
echo "输出文件：$OUTPUT_DIR/output.mp4"
echo "=========================================="

# 显示文件信息
ls -lh output.mp4
ffprobe -v error -show_entries format=duration,size -of default=noprint_wrappers=1 output.mp4
```


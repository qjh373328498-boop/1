## 触发方式

### 方式 1：一体化生成（推荐）
```
用户："帮我做一个产品介绍视频"
触发：video-production-pipeline（总控）
```

### 方式 2：分步执行
```
用户："先下载几个参考视频" → baoyu-youtube-transcript
用户："帮我写脚本" → 文案生成
用户："把脚本转成语音" → tts-voice
用户："根据脚本生成 AI 图片" → ModelScope API
用户："合成视频" → video-use
```

---

## ModelScope AI 图片生成（新增核心能力）

### API 配置

```python
# ModelScope 通义万相 API
BASE_URL = "https://api-inference.modelscope.cn/"
API_KEY = "ms-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # ModelScope Token
MODEL = "Tongyi-MAI/Z-Image-Turbo"  # 通义万相高速版
```

### Python 生成脚本

```python
#!/usr/bin/env python3
"""
ModelScope AI 图片生成脚本
用法：python3 gen_image.py "<prompt>" <output_path>
"""

import requests
import time
import json
import sys
from io import BytesIO

BASE_URL = "https://api-inference.modelscope.cn/"
API_KEY = "ms-cc494f31-690a-4df6-9bea-a9a0d3311c4e"  # 替换为你的 key
MODEL = "Tongyi-MAI/Z-Image-Turbo"

def generate_image(prompt: str, output_path: str, timeout: int = 120):
    """
    使用 ModelScope API 生成图片
    
    Args:
        prompt: 中文或英文提示词
        output_path: 输出文件路径
        timeout: 超时时间（秒）
    """
    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
        "X-ModelScope-Async-Mode": "true",
    }
    
    print(f"🎨 开始生成：{prompt}")
    
    # 提交异步任务
    response = requests.post(
        f"{BASE_URL}v1/images/generations",
        headers=headers,
        data=json.dumps({
            "model": MODEL,
            "prompt": prompt
        }, ensure_ascii=False).encode('utf-8')
    )
    response.raise_for_status()
    
    task_id = response.json()["task_id"]
    print(f"📋 任务 ID: {task_id}")
    
    # 轮询任务状态
    start_time = time.time()
    while True:
        if time.time() - start_time > timeout:
            raise TimeoutError(f"图片生成超时 ({timeout}s)")
        
        result = requests.get(
            f"{BASE_URL}v1/tasks/{task_id}",
            headers={**headers, "X-ModelScope-Task-Type": "image_generation"},
        )
        result.raise_for_status()
        data = result.json()
        status = data["task_status"]
        
        print(f"⏳ 状态：{status}")
        
        if status == "SUCCEED":
            img_url = data["output_images"][0]
            img_data = requests.get(img_url).content
            with open(output_path, 'wb') as f:
                f.write(img_data)
            print(f"✅ 已保存：{output_path}")
            return output_path
            
        elif status == "FAILED":
            error_msg = data.get("error", {}).get("message", "未知错误")
            raise Exception(f"图片生成失败：{error_msg}")
        
        time.sleep(3)


def batch_generate(tasks: list, max_workers: int = 4):
    """
    批量生成图片
    
    Args:
        tasks: [(prompt1, output1), (prompt2, output2), ...]
        max_workers: 最大并发数
    """
    import concurrent.futures
    
    with concurrent.futures.ThreadPoolExecutor(max_workers=max_workers) as executor:
        futures = []
        for prompt, output in tasks:
            future = executor.submit(generate_image, prompt, output)
            futures.append(future)
        
        results = []
        for i, future in enumerate(concurrent.futures.as_completed(futures)):
            try:
                result = future.result()
                results.append(result)
                print(f"[{i+1}/{len(tasks)}] 完成：{result}")
            except Exception as e:
                print(f"[{i+1}/{len(tasks)}] 失败：{e}")
    
    return results


if __name__ == "__main__":
    if len(sys.argv) >= 3:
        prompt = sys.argv[1]
        output = sys.argv[2]
        generate_image(prompt, output)
    elif len(sys.argv) == 2 and sys.argv[1].endswith('.json'):
        # 批量模式
        batch_file = sys.argv[1]
        with open(batch_file, 'r', encoding='utf-8') as f:
            tasks = json.load(f)
        batch_generate(tasks)
    else:
        print("用法:")
        print("  python3 gen_image.py '<prompt>' <output.png>")
        print("  python3 gen_image.py batch.json  # 批量生成")
        print()
        print("batch.json 格式:")
        print('  [["prompt1", "output1.png"], ["prompt2", "output2.png"]]')
```

---

